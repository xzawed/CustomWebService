{
  "name": "custom-web-service",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/lib src/providers",
    "test:integration": "vitest run src/app/api",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:prod": "pnpm build && node -e \"const s=require('child_process').spawn('node',['.next/standalone/server.js'],{stdio:'inherit'});setTimeout(()=>{const h=require('http');h.get('http://localhost:3000/api/v1/health',r=>{console.log('healthcheck:',r.statusCode);s.kill();process.exit(r.statusCode===200?0:1)}).on('error',e=>{console.error('FAIL',e.message);s.kill();process.exit(1)})},4000)\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@auth/drizzle-adapter": "^1.11.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^10.50.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "drizzle-orm": "^0.45.2",
    "isomorphic-dompurify": "^3.10.0",
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.20.0",
    "playwright-core": "^1.59.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.73.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "happy-dom": "^20.9.0",
    "msw": "^2.13.6",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "@vitejs/plugin-react>vite": "^8.0.10",
      "vitest>vite": "^8.0.10"
    }
  }
}

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === AI ===
# Claude (Anthropic) — 기본 Provider
ANTHROPIC_API_KEY=
# xAI Grok — 롤백용 (AI_PROVIDER=grok 으로 전환 가능)
XAI_API_KEY=
# AI_PROVIDER=claude  # claude (기본값) | grok

# === 암호화 키 (사용자 API 키 암호화용) ===
# 생성 방법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# === GitHub (생성 서비스 배포용) ===
GITHUB_TOKEN=
GITHUB_ORG=

# === Railway (생성 서비스 배포용) ===
RAILWAY_TOKEN=

# === API 카탈로그 키 (서버 프록시가 주입 — /api/v1/proxy) ===
# 이름 규칙: API_KEY_<카탈로그 env_var 값>
# Supabase SQL Editor에서 005_api_key_env_vars.sql 실행 후
# SELECT name, auth_config->>'env_var' AS env_var FROM api_catalog WHERE auth_type = 'api_key' ORDER BY name;
# 로 실제 변수명을 확인하여 Railway 환경변수에 등록하세요.
#
# 주요 API 키 목록 (예시):
# API_KEY_OPENWEATHERMAP=          # openweathermap.org → 무료 가입 후 발급
# API_KEY_WEATHERAPICOM=           # weatherapi.com → 무료 가입 후 발급
# API_KEY_NEWSAPI=                 # newsapi.org → 무료 가입 후 발급
# API_KEY_EXCHANGERATEAPI=         # exchangerate-api.com → 무료 가입 후 발급
# API_KEY_OPENAI=                  # openai.com (이미지 생성 등)
# 나머지 env_var 이름은 위 SQL 쿼리로 확인

# === Sentry ===
# SENTRY_DSN=

# === Discord (CI/CD 알림) ===
# DISCORD_WEBHOOK_URL=

# === Admin ===
# ADMIN_API_KEY=

# === App ===
# 로컬 개발:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
#
# 운영 환경 (Railway 환경변수로 설정):
NEXT_PUBLIC_APP_URL=https://xzawed.xyz
NEXT_PUBLIC_ROOT_DOMAIN=xzawed.xyz
#
# === Supabase OAuth 필수 설정 ===
# Supabase Dashboard → Authentication → URL Configuration 에서:
#   Site URL       : https://xzawed.xyz
#   Redirect URLs  : https://xzawed.xyz/callback
